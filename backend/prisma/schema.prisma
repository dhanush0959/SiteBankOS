generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  phone           String?
  whatsappNumber  String?
  passwordHash    String?
  role            UserRole   @default(AGENT)
  profilePhotoUrl String?
  agencyId        String?
  reraNumber      String?
  isVerified      Boolean    @default(false)
  status          UserStatus @default(ACTIVE)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  agency           Agency?            @relation("AgencyMembers", fields: [agencyId], references: [id])
  ownedAgency      Agency?            @relation("AgencyOwner")
  properties       Property[]
  leads            Lead[]
  reminders        FollowUpReminder[]
  auditLogs        AuditLog[]         @relation("ActorLogs")
  refreshTokens    RefreshToken[]
  subscription     Subscription?      @relation("UserSubscription")
  referralsGiven   Referral[]         @relation("ReferralReferrer")
  referralsReceived Referral[]        @relation("ReferralReferred")
  whatsappMessages WhatsAppMessage[]
  payments         Payment[]
  assignedProperties PropertyAssignment[]

  @@index([agencyId])
}

enum UserRole {
  SUPER_ADMIN
  AGENCY_ADMIN
  AGENT
  OWNER
  BUYER
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

model Agency {
  id               String       @id @default(cuid())
  name             String
  logoUrl          String?
  ownerUserId      String       @unique
  address          String?
  customDomain     String?      @unique
  brandingSettings Json?
  status           AgencyStatus @default(ACTIVE)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  owner        User          @relation("AgencyOwner", fields: [ownerUserId], references: [id])
  members      User[]        @relation("AgencyMembers")
  properties   Property[]
  subscription Subscription? @relation("AgencySubscription")
}

enum AgencyStatus {
  ACTIVE
  SUSPENDED
}

model Property {
  id                     String             @id @default(cuid())
  ownerUserId            String
  agencyId               String?
  title                  String
  aiGeneratedTitle       String?
  aiGeneratedDescription String?
  propertyType           PropertyType
  transactionType        TransactionType
  price                  Decimal?           @db.Decimal(15, 2)
  priceNegotiable        Boolean            @default(false)
  priceOnRequest         Boolean            @default(false)
  ownershipType          String?
  location               Json
  specs                  Json
  approvals              Json?
  amenities              Json?
  internalNotes          String?
  reraId                 String?
  lpNumber               String?
  isBankLoanAvailable    Boolean            @default(false)
  status                 PropertyStatus     @default(ACTIVE)
  verificationStatus     VerificationStatus @default(UNVERIFIED)
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt

  owner           User               @relation(fields: [ownerUserId], references: [id], onDelete: Restrict)
  agency          Agency?            @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  media           PropertyMedia[]
  documents       PropertyDocument[]
  smartLinks      SmartLink[]
  leads           Lead[]
  thumbnails      ThumbnailAsset[]
  reminders       FollowUpReminder[]
  nearbyAmenities NearbyAmenity[]
  assignments     PropertyAssignment[]

  @@index([ownerUserId])
  @@index([agencyId])
}

model NearbyAmenity {
  id         String   @id @default(cuid())
  propertyId String
  category   String
  name       String
  distanceKm Float
  rating     Float?
  travelTime String?
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([category])
}

enum PropertyType {
  PLOT
  VILLA
  APARTMENT
  COMMERCIAL
  AGRICULTURAL
  INDUSTRIAL
  FARM_LAND
  INDEPENDENT_HOUSE
}

enum TransactionType {
  SALE
  RENT
  LEASE
  JOINT_DEVELOPMENT
}

enum PropertyStatus {
  ACTIVE
  UNDER_NEGOTIATION
  SOLD
  RENTED
  ARCHIVED
}

enum VerificationStatus {
  UNVERIFIED
  SUBMITTED
  VERIFIED
  REJECTED
}

model PropertyMedia {
  id              String    @id @default(cuid())
  propertyId      String
  fileUrl         String
  cdnUrl          String?
  fileType        MediaType
  orderIndex      Int       @default(0)
  isCover         Boolean   @default(false)
  sizeBytes       BigInt?
  width           Int?
  height          Int?
  durationSeconds Int?
  createdAt       DateTime  @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

enum MediaType {
  PHOTO
  VIDEO
  DOCUMENT
  THUMBNAIL
  AUDIO
}

model PropertyDocument {
  id                 String             @id @default(cuid())
  propertyId         String
  fileUrl            String
  docType            String
  visibility         DocumentVisibility @default(PRIVATE)
  verificationStatus VerificationStatus @default(UNVERIFIED)
  createdAt          DateTime           @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

enum DocumentVisibility {
  PRIVATE
  PUBLIC
  ON_REQUEST
}

model SmartLink {
  id           String          @id @default(cuid())
  propertyId   String
  slug         String          @unique
  status       SmartLinkStatus @default(ACTIVE)
  expiryAt     DateTime?
  passwordHash String?
  shareCount   Int             @default(0)
  createdAt    DateTime        @default(now())

  property Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  events   LinkEvent[]

  @@index([propertyId])
}

enum SmartLinkStatus {
  ACTIVE
  DISABLED
  EXPIRED
}

model LinkEvent {
  id                String   @id @default(cuid())
  smartLinkId       String
  eventType         String
  sessionId         String?
  ipHash            String?
  deviceHash        String?
  referrer          String?
  timeOnPageSeconds Int?
  scrollDepthPct    Int?
  createdAt         DateTime @default(now())

  smartLink SmartLink @relation(fields: [smartLinkId], references: [id], onDelete: Cascade)

  @@index([smartLinkId, createdAt])
}

model Lead {
  id             String     @id @default(cuid())
  propertyId     String
  agentId        String
  name           String?
  phone          String?
  source         String?
  hotScore       Int        @default(0)
  status         LeadStatus @default(NEW)
  lastActivityAt DateTime?
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  property  Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agent     User               @relation(fields: [agentId], references: [id], onDelete: Restrict)
  reminders FollowUpReminder[]

  @@index([propertyId])
  @@index([agentId])
}

enum LeadStatus {
  NEW
  CONTACTED
  SITE_VISIT_SCHEDULED
  NEGOTIATING
  CLOSED
  DEAD
}

model ThumbnailAsset {
  id          String   @id @default(cuid())
  propertyId  String
  templateId  String
  imageUrl    String
  aspectRatio String
  headline    String?
  generatedBy String
  createdAt   DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model SubscriptionPlan {
  id            String         @id @default(cuid())
  name          String         @unique
  limits        Json
  priceInr      Decimal        @db.Decimal(10, 2)
  features      Json
  isActive      Boolean        @default(true)
  subscriptions Subscription[]
  payments      Payment[]
}

model Subscription {
  id               String        @id @default(cuid())
  entityType       EntityType
  userId           String?       @unique
  agencyId         String?       @unique
  planId           String
  startDate        DateTime
  endDate          DateTime
  paymentStatus    PaymentStatus @default(TRIAL)
  paymentProvider  String?
  paymentReference String?

  plan   SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)
  user   User?            @relation("UserSubscription", fields: [userId], references: [id])
  agency Agency?          @relation("AgencySubscription", fields: [agencyId], references: [id])

  @@index([planId])
  @@index([endDate])
}

enum EntityType {
  USER
  AGENCY
}

enum PaymentStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  TRIAL
}

model RefreshToken {
  id         String   @id @default(cuid())
  userId     String
  tokenHash  String   @unique
  deviceInfo String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model FollowUpReminder {
  id         String         @id @default(cuid())
  agentId    String
  leadId     String?
  propertyId String?
  remindAt   DateTime
  note       String?
  status     ReminderStatus @default(PENDING)
  createdAt  DateTime       @default(now())

  agent    User      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([agentId])
  @@index([leadId])
  @@index([propertyId])
}

enum ReminderStatus {
  PENDING
  DONE
  SNOOZED
}

model Referral {
  id             String       @id @default(cuid())
  referrerUserId String
  referredUserId String?
  code           String       @unique
  rewardStatus   RewardStatus @default(PENDING)
  createdAt      DateTime     @default(now())

  referrer     User  @relation("ReferralReferrer", fields: [referrerUserId], references: [id])
  referredUser User? @relation("ReferralReferred", fields: [referredUserId], references: [id])

  @@index([referrerUserId])
}

enum RewardStatus {
  PENDING
  CREDITED
  EXPIRED
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  createdAt   DateTime @default(now())

  actor User @relation("ActorLogs", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId])
  @@index([entityType, entityId])
}

model WhatsAppMessage {
  id             String             @id @default(cuid())
  userId         String?
  toPhone        String
  body           String
  templateName   String?
  wamid          String?            @unique
  status         WhatsAppMsgStatus  @default(QUEUED)
  errorCode      Int?
  errorMessage   String?
  deliveredAt    DateTime?
  readAt         DateTime?
  failedAt       DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([wamid])
  @@index([createdAt])
}

enum WhatsAppMsgStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

model Payment {
  id               String          @id @default(cuid())
  userId           String
  planId           String
  razorpayOrderId  String?
  razorpayPaymentId String?
  amountPaise      Int
  currency         String          @default("INR")
  status           PaymentTxStatus @default(PENDING)
  receiptUrl       String?
  metadata         Json?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([razorpayPaymentId])
  @@index([createdAt])
}

enum PaymentTxStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model PropertyAssignment {
  id         String   @id @default(cuid())
  propertyId String
  agentId    String
  createdAt  DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  agent    User     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([propertyId, agentId])
  @@index([agentId])
}

model IdempotentRequest {
  id              String   @id @default(cuid())
  idempotencyKey  String
  protocolVersion String   @default("v1")
  path            String
  payloadHash     String
  statusCode      Int
  responseBody    Json
  createdAt       DateTime @default(now())

  @@unique([idempotencyKey, protocolVersion])
  @@index([createdAt])
}
