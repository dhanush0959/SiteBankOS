NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

DATABASE_URL=postgresql://postgres:password@localhost:5432/sitebank?schema=public
REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-with-any-long-secret-123456
JWT_REFRESH_SECRET=replace-with-another-long-secret-123456
JWT_EXPIRES_IN=15m

IP_HASH_SALT=change-me-random-salt

# S3 / R2 Storage
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=sitebank
S3_PUBLIC_URL=

# AI (DeepSeek)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Google Maps
GOOGLE_MAPS_API_KEY=

# Payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email
RESEND_API_KEY=
EMAIL_FROM=SiteBank <noreply@sitebank.in>

# WhatsApp
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

SENTRY_DSN=
LOG_LEVEL=info

ENABLE_AI_BUYER_QA=true
ENABLE_VOICE_INPUT=false
